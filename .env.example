# 클라이언트 노출 변수는 NEXT_PUBLIC_ prefix 필수
# 비밀값은 .env.local에만 — 절대 커밋 금지

# giscus 댓글 — 4종 모두 설정되어야 댓글 위젯이 렌더된다 (https://giscus.app 에서 발급)
NEXT_PUBLIC_GISCUS_REPO=
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=
NEXT_PUBLIC_GISCUS_CATEGORY_ID=

# 방문자 분석 
NEXT_PUBLIC_GA_ID=

# 소셜 링크
NEXT_PUBLIC_SOCIAL_GITHUB=https://github.com/yourname
NEXT_PUBLIC_SOCIAL_LINKEDIN=https://www.linkedin.com/in/yourname/
NEXT_PUBLIC_SOCIAL_EMAIL=mailto:you@example.com
